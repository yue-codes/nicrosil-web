---
import Contact from "@components/interactive/Contact.tsx";
import SectionHeader from "@components/ui/SectionHeader.astro";
import PulseDot from "@components/ui/PulseDot.astro";
import Arrow from "@icons/Arrow.astro";

const benefits = [
  {
    colorLight: "#0891B2",
    colorDark: "#22D3EE",
    title: "Respuesta en menos de 24 h",
    description: "Nada de silencio radial. Recibirás mi análisis inicial el mismo día hábil.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    colorLight: "#16A34A",
    colorDark: "#4ADE80",
    title: "Sin compromisos",
    description: "La primera conversación es gratuita y sin presión. Decidimos juntos si encajamos.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    colorLight: "#7C3AED",
    colorDark: "#A78BFA",
    title: "Análisis técnico incluido",
    description: "Reviso tu situación digital actual y te entrego observaciones concretas.",
    iconHtml: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
  },
];
---

<section
  id="contacto"
  class="relative overflow-hidden bg-[#F0FBFC] py-24 dark:bg-[#06100A]"
  aria-labelledby="contacto-heading"
>
  <!-- Orbs de ambiente -->
  <div aria-hidden="true" class="pointer-events-none absolute -left-40 top-1/4 h-[28rem] w-[28rem] rounded-full bg-cyan-400/20 blur-3xl dark:bg-cyan-500/18"></div>
  <div aria-hidden="true" class="pointer-events-none absolute right-0 bottom-0 h-[22rem] w-[22rem] translate-x-1/3 translate-y-1/3 rounded-full bg-green-400/15 blur-3xl dark:bg-green-500/12"></div>
  <div aria-hidden="true" class="pointer-events-none absolute right-1/4 top-0 h-48 w-48 -translate-y-1/2 rounded-full bg-violet-400/10 blur-2xl dark:bg-violet-500/10"></div>

  <div class="relative mx-auto max-w-6xl px-6">

    <!-- Encabezado de sección centrado -->
    <SectionHeader
      eyebrow="Contacto"
      id="contacto-heading"
      description="Cuéntame tu proyecto. Sin compromiso, sin tecnicismos. En menos de 24 horas tienes mi análisis inicial."
    >
      Planta tu jardín<br class="hidden sm:block" />
      <span class="text-cyan-700 dark:text-cyan-400">
        digital hoy
      </span>
    </SectionHeader>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">

      <!-- Columna izquierda: panel de información -->
      <div class="relative overflow-hidden rounded-3xl border border-cyan-200/60 bg-white shadow-lg dark:border-cyan-900/30 dark:bg-white/[0.04]">

        <!-- Franja de acento superior -->
        <div class="h-1 w-full bg-gradient-to-r from-green-500 via-cyan-500 to-violet-500"></div>

        <!-- Decoración de fondo — planta grande sutil -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute -bottom-6 -right-6 select-none opacity-[0.04] dark:opacity-[0.06]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="220" height="220" viewBox="0 0 24 24" fill="currentColor" class="text-cyan-900 dark:text-cyan-200">
            <path d="M7 20h10M10 20c5.5-2.5.8-6.4 3-10M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8zM14.1 6a7 7 0 0 1 1.1 7.14c-1.2.4-2.3.5-3.4.3-.8-2.1-1-4.1-.5-6.4 1.1-.5 2-.7 2.8-1z"/>
          </svg>
        </div>

        <div class="p-8">
          <!-- Disponibilidad -->
          <div class="mb-7 inline-flex items-center gap-2 rounded-full border border-green-600/25 bg-green-500/10 px-3.5 py-1.5 dark:border-green-500/20">
            <PulseDot color="green" />
            <span class="text-xs font-semibold text-green-600 dark:text-green-400">
              Disponible para nuevos proyectos
            </span>
          </div>

          <h3 class="mb-2 font-display text-2xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50">
            ¿Hablamos?
          </h3>
          <p class="mb-8 text-sm leading-relaxed text-zinc-500 dark:text-zinc-400">
            Cada proyecto comienza con una conversación honesta. Cuéntame tu idea y construimos desde ahí.
          </p>

          <!-- 3 beneficios -->
          <div class="mb-8 flex flex-col gap-4">
            {benefits.map(({ colorLight, title, description, iconHtml }) => (
              <div class="flex items-start gap-4">
                <div
                  class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl"
                  style={`background-color: ${colorLight}18; color: ${colorLight};`}
                >
                  <Fragment set:html={iconHtml} />
                </div>
                <div>
                  <p class="mb-0.5 text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                    {title}
                  </p>
                  <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">
                    {description}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <!-- Separador -->
          <div class="mb-6 h-px w-full bg-zinc-100 dark:bg-white/8"></div>

          <!-- Email como CTA destacado -->
          <a
            href="mailto:contacto@nicrosil.com"
            class="group flex items-center gap-3 rounded-2xl border border-zinc-200 bg-zinc-50 px-5 py-4 text-sm font-medium text-zinc-700 transition-all hover:border-cyan-300 hover:bg-cyan-50 hover:text-cyan-700 dark:border-white/8 dark:bg-white/5 dark:text-zinc-300 dark:hover:border-cyan-700/50 dark:hover:bg-cyan-500/10 dark:hover:text-cyan-300"
          >
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-cyan-600 shadow-sm transition-colors group-hover:bg-cyan-600 group-hover:text-white dark:bg-white/10 dark:text-cyan-400 dark:group-hover:bg-cyan-500 dark:group-hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </span>
            <span class="flex-1">contacto@nicrosil.com</span>
            <Arrow size={14} class="opacity-40 transition-all group-hover:translate-x-0.5 group-hover:opacity-80" />
          </a>
        </div>
      </div>

      <!-- Columna derecha: formulario -->
      <div class="relative overflow-hidden rounded-3xl border border-zinc-200/80 bg-white shadow-lg dark:border-white/8 dark:bg-white/[0.04]">
        <!-- Franja superior sutil -->
        <div class="h-1 w-full bg-gradient-to-r from-cyan-500 to-cyan-400 opacity-60"></div>
        <div class="p-8">
          <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-cyan-600 dark:text-cyan-400">
            Formulario de contacto
          </p>
          <p class="mb-6 text-lg font-bold text-zinc-900 dark:text-zinc-50">
            Cuéntame tu proyecto
          </p>
          <Contact client:visible />
        </div>
      </div>

    </div>
  </div>
</section>
